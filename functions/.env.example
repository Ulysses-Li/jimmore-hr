# 複製為 functions/.env.local 供 Emulator 使用；正式環境用 Firebase/Google Cloud 設定。
FUNCTIONS_REGION=asia-east1
TIME_ZONE=Asia/Taipei
WEBAUTHN_RP_ID=jimmore-workhub.web.app
WEBAUTHN_RP_NAME=Jimmore WorkHub
WEBAUTHN_ORIGINS=https://jimmore-workhub.web.app,https://jimmore-workhub.firebaseapp.com
CHALLENGE_TTL_SECONDS=300
APP_CHECK_ENFORCEMENT=true

# Emulator 範例（切勿部署此組值）：
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
# APP_CHECK_ENFORCEMENT=false
